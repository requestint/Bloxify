      "id": "ada7f1724e9e4d33b856e8e44bd230c2",
      "binding": "COMMANDS"
    },
    {
      "id": "cb624d99caa84c5893df48dc13e66ec2",
      "binding": "rbx-http-cache"
    }
  ],
  "vars": {
